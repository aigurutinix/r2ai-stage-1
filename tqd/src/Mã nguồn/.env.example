# ============================================================
# R2AI — Environment Configuration
# Copy this file to .env and fill in your values.
# All paths below are for LOCAL (non-Kaggle) runs.
# On Kaggle, the notebooks auto-detect /kaggle/input and use
# default Kaggle paths — no .env needed.
# ============================================================

# ---- Data paths (pipeline-corpus.ipynb) ----
# Directory containing all corpus JSONL files
DATASET_DIR=./data

# ---- Data paths (llm-gen.ipynb) ----
# Directory of old submission zip files (for voting ensemble)
SUBMISSIONS_DIR=./old_submission

# SME merged legal corpus
SME_MERGED=./data/corpus_luat_sme_merged_v3.jsonl

# Fallback article corpus
TH_ARTICLES=./data/processed/th1nhng0_articles_v2.jsonl

# Working/output directory
WORK_DIR=.

# Checkpoint file (JSONL) — append-only, safe to resume
CHECKPOINT_FILE=./data/eval/qwen3_14b_llm_filter_checkpoint.jsonl

# Final output paths
OUTPUT_JSON=./submissions/results_qwen3_14b_llm_filter.json
OUTPUT_ZIP=./submissions/results_qwen3_14b_llm_filter.zip

# ---- Model config (llm-gen.ipynb) ----
# HuggingFace model ID for the LLM
MODEL_ID=Qwen/Qwen3-14B

# Enable 4-bit quantisation (1=yes, 0=no). Requires bitsandbytes + CUDA.
LOAD_IN_4BIT=1

# Thinking mode for Qwen3: "off" (faster) or "on"
THINKING=off

# ---- Inference hyperparameters ----
MAX_ARTICLES=10
MIN_VOTE=1
ARTICLE_CHARS=6000
MAX_INPUT_TOKENS=24576
MAX_NEW_TOKENS=1600
REVIEW_MAX_NEW_TOKENS=1600
FALLBACK_TOP=3
TEMPERATURE=0
REVIEW_TEMPERATURE=0
RETRIES=1

# ---- Optional ----
# HuggingFace auth token (for gated models or higher rate limits)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
