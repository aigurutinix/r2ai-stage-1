# Copy to .env (local ingest) or .env.cloud (Qdrant Cloud trial).
# Do not commit .env / .env.cloud to git.

# --- Local ingest (việc 1) ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=          # not needed for local Qdrant
QDRANT_COLLECTION=legal_documents

# --- Qdrant Cloud ---
QDRANT_URL=https://YOUR-CLUSTER.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your-api-key
QDRANT_COLLECTION=vld_business_law_v2
QDRANT_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=bm25

# HuggingFace models (when local models/ is not present)
EMBED_MODEL_PATH=BAAI/bge-m3
RERANK_MODEL_PATH=BAAI/bge-reranker-v2-m3
