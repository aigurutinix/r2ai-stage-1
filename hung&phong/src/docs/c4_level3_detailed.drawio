        <mxCell id="f6" style="endArrow=block;html=1;exitX=0.5;exitY=1;entryX=0.3;entryY=0;" edge="1" parent="1" source="qsearch" target="merge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f7" style="endArrow=block;html=1;exitX=0.5;exitY=1;entryX=0.8;entryY=0;" edge="1" parent="1" source="bm25" target="merge"><mxGeometry relative="1" as="geometry" /></mxCell>
