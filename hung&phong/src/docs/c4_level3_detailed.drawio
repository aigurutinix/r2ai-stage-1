<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="c3-detailed" name="C4 L3 - Component chi tiết">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t" value="C4 — Mức 3 (chi tiết): Component trong RAG Orchestrator — luồng truy hồi 1 câu hỏi" style="text;html=1;fontSize=15;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1100" height="26" as="geometry" /></mxCell>
        <mxCell id="lg" value="■ Component (xanh nhạt)   ■ Container/model (xanh)   ⛁ Data store (trụ)   ─► luồng chính   ┈► dùng data store / tùy chọn" style="text;html=1;fontSize=11;align=left;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="40" y="46" width="1100" height="20" as="geometry" /></mxCell>

        <!-- LEFT: config + optional -->
        <mxCell id="cfg" value="&lt;b&gt;Settings&lt;/b&gt;&lt;br&gt;[config.py]&lt;br&gt;Nạp .env: fetch_k, top_k, hybrid_search, use_reranker, RERANKER_MODEL, LLM_TEMPERATURE." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D4E8FC;strokeColor=#6C8EBF;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="40" y="90" width="260" height="100" as="geometry" /></mxCell>
        <mxCell id="decomp" value="&lt;b&gt;decompose(query)&lt;/b&gt;&lt;br&gt;[decompose.py] — tùy chọn&lt;br&gt;Tách câu tình huống → subquery (đa-query, tăng recall)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="40" y="280" width="260" height="90" as="geometry" /></mxCell>
        <mxCell id="sq" value="⛁ &lt;b&gt;subqueries.json&lt;/b&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1"><mxGeometry x="90" y="410" width="160" height="70" as="geometry" /></mxCell>

        <!-- BACKBONE center -->
        <mxCell id="entry" value="&lt;b&gt;RAGPipeline.retrieve(query, top_k)&lt;/b&gt;&lt;br&gt;[rag.py] — điều phối, trả list[hit] xếp theo adj_score" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="430" y="90" width="320" height="70" as="geometry" /></mxCell>
        <mxCell id="norm" value="&lt;b&gt;normalize_vn(text)&lt;/b&gt;&lt;br&gt;[textnorm.py] — chuẩn hoá dấu thanh (khỏan→khoản), áp đối xứng query+corpus" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="430" y="200" width="320" height="70" as="geometry" /></mxCell>

        <mxCell id="embed" value="&lt;b&gt;Embedder.encode(query)&lt;/b&gt;&lt;br&gt;[sentence-transformers]&lt;br&gt;AITeamVN-v2 → vector 1024d" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="330" y="320" width="240" height="80" as="geometry" /></mxCell>
        <mxCell id="bm25" value="&lt;b&gt;BM25Index.search(query)&lt;/b&gt;&lt;br&gt;[bm25.py] — lexical top fetch_k (số điều, mã VB)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="630" y="430" width="240" height="80" as="geometry" /></mxCell>
        <mxCell id="qsearch" value="&lt;b&gt;QdrantStore.search(vec, fetch_k)&lt;/b&gt;&lt;br&gt;[qdrant_store.py] — dense ANN (HNSW, filter-first) top fetch_k" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="330" y="440" width="240" height="80" as="geometry" /></mxCell>

        <mxCell id="merge" value="&lt;b&gt;cand_from_hit + merge_cands&lt;/b&gt;&lt;br&gt;[build_submission_v12.py]&lt;br&gt;hit→{art,doc,rr,_key}; hợp nhất dense+BM25, khử trùng theo _key" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="430" y="570" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="collapse" value="&lt;b&gt;collapse(cands)&lt;/b&gt;&lt;br&gt;[build_submission_v12.py] — gộp theo HỌ LUẬT (cùng tên luật)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="430" y="680" width="320" height="60" as="geometry" /></mxCell>
        <mxCell id="rerank" value="&lt;b&gt;reranker.rerank(query, hits)&lt;/b&gt;&lt;br&gt;[reranker.py] — cross-encoder compute_score → rerank_score (model đổi qua RERANKER_MODEL)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="430" y="770" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="adj" value="&lt;b&gt;_rerank_adjust(payload)&lt;/b&gt;&lt;br&gt;[rag.py] — adj_score = rerank + phạt hết-hiệu-lực + boost luật gốc/năm mới" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="430" y="880" width="320" height="70" as="geometry" /></mxCell>
        <mxCell id="cver" value="&lt;b&gt;collapse_versions(arts)&lt;/b&gt;&lt;br&gt;[exp_v24.py: family_tag + _WF_FAMILY] — bỏ bản CŨ khi bản mới đồng hiện diện (recall-safe)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="430" y="980" width="320" height="80" as="geometry" /></mxCell>

        <!-- SELECTION row -->
        <mxCell id="selb" value="Selection — chọn 1 chiến lược" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#B85450;verticalAlign=top;fontStyle=2;fontColor=#B85450;" vertex="1" parent="1"><mxGeometry x="40" y="1110" width="900" height="220" as="geometry" /></mxCell>
        <mxCell id="adaptive" value="&lt;b&gt;adaptive(cands, t_abs, ratio, max_k)&lt;/b&gt;&lt;br&gt;[build_submission_v12.py]&lt;br&gt;Giữ theo NGƯỠNG điểm. Nhanh, no-LLM." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="60" y="1160" width="260" height="100" as="geometry" /></mxCell>
        <mxCell id="judge" value="&lt;b&gt;judge / judge_question&lt;/b&gt;&lt;br&gt;[llm_judge_parallel.py]&lt;br&gt;Qwen CÓ/KHÔNG từng điều (think). keep rank&lt;2 HOẶC CÓ. Song song." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="350" y="1160" width="260" height="100" as="geometry" /></mxCell>
        <mxCell id="listwise" value="&lt;b&gt;listwise_select(query, cands)&lt;/b&gt;&lt;br&gt;[test_listwise.py]&lt;br&gt;Qwen đọc CẢ pool, chọn subset + xếp hạng (few-shot, think)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="640" y="1160" width="260" height="100" as="geometry" /></mxCell>

        <mxCell id="out" value="&lt;b&gt;rebuild_docs(arts) → output&lt;/b&gt;&lt;br&gt;[build_submission_v12.py] — relevant_articles + relevant_docs" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;fontStyle=1" vertex="1" parent="1"><mxGeometry x="430" y="1390" width="320" height="70" as="geometry" /></mxCell>

        <!-- RIGHT: stores aligned with consumers -->
        <mxCell id="dQ" value="⛁ &lt;b&gt;Qdrant&lt;/b&gt;&lt;br&gt;vbpl_aiteam (285k)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1"><mxGeometry x="630" y="320" width="170" height="90" as="geometry" /></mxCell>
        <mxCell id="dB" value="⛁ &lt;b&gt;BM25 pickle&lt;/b&gt;&lt;br&gt;bm25_vbpl_aiteam.pkl" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1"><mxGeometry x="930" y="430" width="170" height="80" as="geometry" /></mxCell>
        <mxCell id="mR" value="&lt;b&gt;Reranker model&lt;/b&gt;&lt;br&gt;[GPU] cross-encoder&lt;br&gt;AITeamVN / FT v3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1"><mxGeometry x="830" y="775" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="dV" value="⛁ &lt;b&gt;version_families.json&lt;/b&gt;&lt;br&gt;134 họ phiên bản" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1"><mxGeometry x="830" y="980" width="180" height="80" as="geometry" /></mxCell>

        <!-- LLM cluster bottom-right -->
        <mxCell id="ltext" value="&lt;b&gt;load_text_lookup&lt;/b&gt;&lt;br&gt;[build_submission_v12.py]&lt;br&gt;scroll Qdrant → art→text cho judge/listwise" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1080" y="1080" width="260" height="90" as="geometry" /></mxCell>
        <mxCell id="llmc" value="&lt;b&gt;LLMClient.complete(sys,user,think)&lt;/b&gt;&lt;br&gt;[llm.py] — bọc Ollama; think→/think+strip" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3A6FA5;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="1080" y="1200" width="260" height="80" as="geometry" /></mxCell>
        <mxCell id="mO" value="&lt;b&gt;Ollama / Qwen3.5:9b&lt;/b&gt;&lt;br&gt;[GPU] qwen-vbpl, think" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1"><mxGeometry x="1110" y="1320" width="200" height="70" as="geometry" /></mxCell>

