        <mxCell id="f4" style="endArrow=block;html=1;exitX=0.8;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="norm" target="bm25"><mxGeometry relative="1" as="geometry" /></mxCell>
