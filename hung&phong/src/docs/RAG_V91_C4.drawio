<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="v91-c2" name="C4 L2 - RAG v91 Containers">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="C4 Level 2 - Kiến trúc tổng quan RAG v91" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note" value="v91 = graph-aware retrieval + hybrid dense/BM25 + AITeamVN reranker + deterministic selector guards. Không dùng LLM làm final selector." style="text;html=1;fontSize=12;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="1150" height="24" as="geometry" />
        </mxCell>

        <mxCell id="person" value="&lt;b&gt;Người dùng / Bộ câu hỏi&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;Câu hỏi pháp lý dạng tình huống, thường nhiều vế." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;strokeColor=#052E56;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="boundary" value="Hệ thống RAG VBPL - v91" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#0B4884;verticalAlign=top;fontStyle=2;fontColor=#0B4884;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="1140" height="760" as="geometry" />
        </mxCell>

        <mxCell id="builder" value="&lt;b&gt;Submission/Run Builder&lt;/b&gt;&lt;br&gt;[Python script]&lt;br&gt;Đọc base submission, rebuild target IDs, ghi results.json và sidecar audit." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="380" y="160" width="250" height="110" as="geometry" />
        </mxCell>

        <mxCell id="orchestrator" value="&lt;b&gt;Graph-aware RAG Orchestrator&lt;/b&gt;&lt;br&gt;[build_v81_graph_aware_arch.py + build_v66_arch_pipeline.py]&lt;br&gt;Điều phối retrieval, graph scoring, selector guard, output article/doc IDs." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1168BD;fontColor=#ffffff;strokeColor=#0B4884;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="150" width="310" height="130" as="geometry" />
        </mxCell>

        <mxCell id="retrieval" value="&lt;b&gt;Hybrid Retrieval Engine&lt;/b&gt;&lt;br&gt;[backend/rag.py]&lt;br&gt;Normalize query, dense search Qdrant, BM25 search, merge, rerank, dedupe." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="690" y="340" width="310" height="120" as="geometry" />
        </mxCell>

        <mxCell id="selector" value="&lt;b&gt;Deterministic Selector + Guards&lt;/b&gt;&lt;br&gt;[build_v66_arch_pipeline.py]&lt;br&gt;Chọn căn cứ theo score, clause coverage, same-doc evidence, domain/off-topic guards." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="690" y="530" width="310" height="125" as="geometry" />
        </mxCell>

        <mxCell id="embed" value="&lt;b&gt;Embedding Model&lt;/b&gt;&lt;br&gt;[sentence-transformers]&lt;br&gt;AITeamVN/Vietnamese_Embedding_v2&lt;br&gt;1024d, GPU fp16." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="380" y="340" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="reranker" value="&lt;b&gt;Reranker Model&lt;/b&gt;&lt;br&gt;[FlagEmbedding]&lt;br&gt;AITeamVN/Vietnamese_Reranker&lt;br&gt;Cross-encoder rerank_score." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="380" y="500" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="llm" value="&lt;b&gt;LLM - optional audit only&lt;/b&gt;&lt;br&gt;[Ollama qwen-vbpl]&lt;br&gt;Có thể dùng llm_verify, nhưng v91 artifact hiện tại không dùng LLM để mutate output." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D4E8FC;fontColor=#000000;strokeColor=#6C8EBF;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="660" width="240" height="110" as="geometry" />
        </mxCell>

        <mxCell id="qdrant" value="⛁ &lt;b&gt;Qdrant Vector DB&lt;/b&gt;&lt;br&gt;Collection:&lt;br&gt;vbpl_aiteam_meta_parsefix_20260628&lt;br&gt;285,002 points, payload pháp lý." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="1080" y="320" width="250" height="120" as="geometry" />
        </mxCell>

        <mxCell id="bm25" value="⛁ &lt;b&gt;BM25 Index&lt;/b&gt;&lt;br&gt;data/bm25_vbpl_aiteam_meta_parsefix_20260628.pkl&lt;br&gt;Lexical match cho số hiệu, điều, thuật ngữ." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="1080" y="470" width="250" height="115" as="geometry" />
        </mxCell>

        <mxCell id="graphs" value="⛁ &lt;b&gt;Metadata Graphs&lt;/b&gt;&lt;br&gt;doc_metadata_graph_20260630.json&lt;br&gt;legal_effect_graph_20260630.json&lt;br&gt;Cutoff 2026-03-31, successors, obsolete/current prefixes." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="1080" y="620" width="250" height="130" as="geometry" />
        </mxCell>

        <mxCell id="output" value="&lt;b&gt;Kết quả&lt;/b&gt;&lt;br&gt;[results.json + sidecar]&lt;br&gt;relevant_articles, relevant_docs, pool audit." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#6B6B6B;" vertex="1" parent="1">
          <mxGeometry x="690" y="730" width="310" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="questions / target IDs" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="person" target="builder"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="run one question" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="builder" target="orchestrator"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="retrieve pool" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="orchestrator" target="retrieval"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="embed query" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="retrieval" target="embed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="dense search" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="retrieval" target="qdrant"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="lexical search" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="retrieval" target="bm25"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="rerank candidates" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="retrieval" target="reranker"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="graph-aware score" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="orchestrator" target="graphs"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="ranked pool" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="retrieval" target="selector"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" value="selected articles" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="selector" target="output"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" value="optional audit" style="endArrow=open;html=1;fontSize=11;dashed=1;" edge="1" parent="1" source="selector" target="llm"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="v91-c3" name="C4 L3 - RAG v91 Component Flow">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title3" value="C4 Level 3 - Luồng component RAG v91 cho một câu hỏi" style="text;html=1;fontSize=18;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend3" value="Xanh đậm = container/model/data store, xanh nhạt = component xử lý, nét đứt = tùy chọn hoặc phụ trợ." style="text;html=1;fontSize=12;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1000" height="24" as="geometry" />
        </mxCell>

        <mxCell id="q" value="&lt;b&gt;Question&lt;/b&gt;&lt;br&gt;Câu hỏi pháp lý, có thể nhiều vế." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;strokeColor=#052E56;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="base" value="&lt;b&gt;Base submission row&lt;/b&gt;&lt;br&gt;Giữ ID ngoài target; target IDs được rebuild." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D4E8FC;fontColor=#000000;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="subq" value="⛁ &lt;b&gt;subqueries.json&lt;/b&gt;&lt;br&gt;Chỉ dùng nếu câu hỏi phức tạp và subquery pass safe_subquery." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="210" height="95" as="geometry" />
        </mxCell>

        <mxCell id="retrievepool" value="&lt;b&gt;retrieve_pool()&lt;/b&gt;&lt;br&gt;Nguồn query = orig + sub1..subN an toàn.&lt;br&gt;orig_topk=14, sub_topk=8 mặc định." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="360" y="130" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="normalize" value="&lt;b&gt;normalize_vn()&lt;/b&gt;&lt;br&gt;Chuẩn hóa query trước khi retrieve." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="360" y="270" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="embed3" value="&lt;b&gt;EmbeddingClient.embed_one()&lt;/b&gt;&lt;br&gt;AITeamVN/Vietnamese_Embedding_v2&lt;br&gt;Vector 1024d." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="300" y="390" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="qdrant3" value="&lt;b&gt;Qdrant dense search&lt;/b&gt;&lt;br&gt;filter-first nếu query có số hiệu/điều;&lt;br&gt;fallback vector-only." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="300" y="530" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="bm253" value="&lt;b&gt;BM25Index.search()&lt;/b&gt;&lt;br&gt;Lexical search cho số văn bản, điều, thuật ngữ pháp lý." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="640" y="530" width="260" height="95" as="geometry" />
        </mxCell>
        <mxCell id="union" value="&lt;b&gt;Union dense ∪ BM25&lt;/b&gt;&lt;br&gt;Dedup ứng viên theo hit id hoặc so_ky_hieu#dieu_so." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="470" y="680" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rerank3" value="&lt;b&gt;reranker.rerank()&lt;/b&gt;&lt;br&gt;AITeamVN/Vietnamese_Reranker&lt;br&gt;Gán rerank_score cho từng hit." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="470" y="810" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ragadjust" value="&lt;b&gt;adj_score trong RAGPipeline&lt;/b&gt;&lt;br&gt;rerank_score + soft adjust theo loại văn bản, năm, hiệu lực nếu có." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="470" y="950" width="260" height="85" as="geometry" />
        </mxCell>

        <mxCell id="cand" value="&lt;b&gt;candidate_from_hit()&lt;/b&gt;&lt;br&gt;Chuẩn hóa hit thành candidate: art, prefix, text, title, score_raw, issue_year." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="830" y="130" width="285" height="95" as="geometry" />
        </mxCell>
        <mxCell id="graphscore" value="&lt;b&gt;graph_base_score()&lt;/b&gt;&lt;br&gt;Áp dụng graph: obsolete penalty, still-current-old boost, cutoff 2026-03-31, amendment/consolidated signal." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="830" y="270" width="285" height="115" as="geometry" />
        </mxCell>
        <mxCell id="pool" value="&lt;b&gt;Ranked pool&lt;/b&gt;&lt;br&gt;Sort theo score_arch, score_raw.&lt;br&gt;Ghi vào sidecar để audit." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="830" y="430" width="285" height="85" as="geometry" />
        </mxCell>
        <mxCell id="select" value="&lt;b&gt;select_candidates()&lt;/b&gt;&lt;br&gt;Threshold theo câu phức tạp; max_k=3/4/5; chọn ứng viên acceptable." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="830" y="570" width="285" height="95" as="geometry" />
        </mxCell>
        <mxCell id="clause" value="&lt;b&gt;Clause coverage&lt;/b&gt;&lt;br&gt;split_clauses(), covers_clause(), clause_groups().&lt;br&gt;Bổ sung vế còn thiếu nếu có chứng cứ." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="830" y="720" width="285" height="105" as="geometry" />
        </mxCell>
        <mxCell id="samedoc" value="&lt;b&gt;Same-doc evidence guard&lt;/b&gt;&lt;br&gt;add_clause_evidence() chỉ thêm điều cùng document đã chọn, giảm rủi ro mất DOC precision." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="830" y="880" width="285" height="95" as="geometry" />
        </mxCell>
        <mxCell id="filters" value="&lt;b&gt;Final guards / filters&lt;/b&gt;&lt;br&gt;off_topic, direct_evidence, generic/penalty filter, old-version filter, civil-general guard, dedupe_articles." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;strokeColor=#3A6FA5;" vertex="1" parent="1">
          <mxGeometry x="830" y="1030" width="285" height="105" as="geometry" />
        </mxCell>

        <mxCell id="docsout" value="&lt;b&gt;rebuild_docs() + output row&lt;/b&gt;&lt;br&gt;Ghi relevant_articles, relevant_docs.&lt;br&gt;Ghi sidecar: old_articles, new_articles, pool." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1168BD;fontColor=#ffffff;strokeColor=#0B4884;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="570" width="300" height="115" as="geometry" />
        </mxCell>
        <mxCell id="sidecar" value="⛁ &lt;b&gt;v91 sidecar&lt;/b&gt;&lt;br&gt;Audit từng ID: pool top12, score_raw, score_arch, snippet." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="1240" y="740" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="artifact" value="⛁ &lt;b&gt;submission_v91_*.json / .zip&lt;/b&gt;&lt;br&gt;Artifact nộp hoặc smoke/fullrun guard." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="1240" y="880" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="gstore" value="⛁ &lt;b&gt;Metadata graphs&lt;/b&gt;&lt;br&gt;doc_metadata_graph_20260630.json&lt;br&gt;legal_effect_graph_20260630.json" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="1210" y="260" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="qstore" value="⛁ &lt;b&gt;Qdrant&lt;/b&gt;&lt;br&gt;vbpl_aiteam_meta_parsefix_20260628" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="bstore" value="⛁ &lt;b&gt;BM25 pickle&lt;/b&gt;&lt;br&gt;bm25_vbpl_aiteam_meta_parsefix_20260628.pkl" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#2E5E8C;" vertex="1" parent="1">
          <mxGeometry x="60" y="710" width="210" height="100" as="geometry" />
        </mxCell>

        <mxCell id="a1" style="endArrow=block;html=1;" edge="1" parent="1" source="q" target="retrievepool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a2" style="endArrow=open;html=1;dashed=1;" edge="1" parent="1" source="subq" target="retrievepool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a3" style="endArrow=block;html=1;" edge="1" parent="1" source="retrievepool" target="normalize"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a4" style="endArrow=block;html=1;" edge="1" parent="1" source="normalize" target="embed3"><mxGeometry relative="1" as="geometry" /></mxCell>
