<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="c1-context" name="C1 - System Context">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c1-title" value="C4 — Mức 1: System Context — Chatbot Tra cứu &amp; Hỏi đáp Văn bản Pháp luật VN" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="30" as="geometry" /></mxCell>
        <mxCell id="c1-person" value="&lt;b&gt;Người dùng / Thí sinh&lt;/b&gt;&lt;br&gt;[Person]&lt;br&gt;&lt;br&gt;Đặt câu hỏi tình huống pháp lý (văn nói), cần đúng điều luật &amp; văn bản làm căn cứ." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;strokeColor=#052E56;" vertex="1" parent="1"><mxGeometry x="120" y="100" width="200" height="110" as="geometry" /></mxCell>
        <mxCell id="c1-system" value="&lt;b&gt;Hệ thống RAG VBPL&lt;/b&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;br&gt;Truy hồi điều luật/văn bản liên quan (Stage 1) &amp; sinh câu trả lời (Stage 2) từ kho VBPL VN, dựa trên LLM + embedding + reranker." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1168BD;fontColor=#ffffff;strokeColor=#0B4884;" vertex="1" parent="1"><mxGeometry x="470" y="95" width="240" height="120" as="geometry" /></mxCell>
        <mxCell id="c1-btc" value="&lt;b&gt;Hệ thống chấm điểm BTC&lt;/b&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;Nhận results.json, chấm ARTICLES_F2 / DOCS_F2 (recall×2 &gt; precision)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#6B6B6B;" vertex="1" parent="1"><mxGeometry x="850" y="95" width="220" height="120" as="geometry" /></mxCell>
        <mxCell id="c1-src" value="&lt;b&gt;Nguồn VBPL&lt;/b&gt;&lt;br&gt;[External System]&lt;br&gt;&lt;br&gt;Văn bản quy phạm pháp luật VN (luật, nghị định, thông tư...) — nguồn ingest corpus." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;strokeColor=#6B6B6B;" vertex="1" parent="1"><mxGeometry x="470" y="320" width="240" height="110" as="geometry" /></mxCell>
        <mxCell id="c1-e1" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="c1-person" target="c1-system"><mxGeometry relative="1" as="geometry" /><mxCell id="c1-e1l" value="câu hỏi pháp lý" connectable="0" vertex="1" parent="c1-e1"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c1-e2" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="c1-system" target="c1-btc"><mxGeometry relative="1" as="geometry" /><mxCell id="c1-e2l" value="nộp results.json" connectable="0" vertex="1" parent="c1-e2"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c1-e3" style="endArrow=block;html=1;fontSize=11;" edge="1" parent="1" source="c1-src" target="c1-system"><mxGeometry relative="1" as="geometry" /><mxCell id="c1-e3l" value="ingest văn bản" connectable="0" vertex="1" parent="c1-e3"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="c2-container" name="C2 - Container">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c2-title" value="C4 — Mức 2: Container — bên trong Hệ thống RAG VBPL" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="30" as="geometry" /></mxCell>
        <mxCell id="c2-person" value="&lt;b&gt;Người dùng / Thí sinh&lt;/b&gt;&lt;br&gt;[Person]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="60" y="80" width="180" height="70" as="geometry" /></mxCell>

        <mxCell id="c2-boundary" value="Hệ thống RAG VBPL" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#0B4884;verticalAlign=top;fontStyle=2;fontColor=#0B4884;" vertex="1" parent="1"><mxGeometry x="40" y="200" width="1500" height="740" as="geometry" /></mxCell>

        <mxCell id="c2-orch" value="&lt;b&gt;RAG Orchestrator&lt;/b&gt;&lt;br&gt;[Container: Python — backend/rag.py]&lt;br&gt;&lt;br&gt;Điều phối toàn pipeline truy hồi: chuẩn hoá → fetch → merge → rerank → dedup → chọn lọc." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="600" y="270" width="260" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-embed" value="&lt;b&gt;Embedding Model&lt;/b&gt;&lt;br&gt;[Container: sentence-transformers, GPU]&lt;br&gt;AITeamVN/Vietnamese_Embedding_v2 (1024-dim) — mã hoá truy vấn &amp; chunk." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="80" y="270" width="240" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-qdrant" value="&lt;b&gt;Qdrant Vector DB&lt;/b&gt;&lt;br&gt;[Container: Docker, port 6333]&lt;br&gt;Collection vbpl_aiteam — ~285k chunk + payload (so_ky_hieu, dieu, text). HNSW native." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="80" y="430" width="240" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-bm25" value="&lt;b&gt;BM25 Index&lt;/b&gt;&lt;br&gt;[Container: rank_bm25 pickle]&lt;br&gt;bm25_vbpl_aiteam.pkl (~285k doc) — truy hồi lexical (từ khoá, số điều)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="80" y="590" width="240" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-rerank" value="&lt;b&gt;Reranker (cross-encoder)&lt;/b&gt;&lt;br&gt;[Container: FlagEmbedding, GPU]&lt;br&gt;AITeamVN/Vietnamese_Reranker hoặc bản fine-tune LoRA (reranker_vbpl_v3). Chấm lại (query, điều)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="600" y="430" width="260" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-llm" value="&lt;b&gt;LLM (Qwen)&lt;/b&gt;&lt;br&gt;[Container: Ollama — qwen-vbpl / Qwen3.5:9b]&lt;br&gt;Judge CÓ/KHÔNG, listwise chọn subset, decompose, sinh answer. think=True." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="600" y="590" width="260" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-vmap" value="&lt;b&gt;Version-family Map&lt;/b&gt;&lt;br&gt;[Data: version_families.json]&lt;br&gt;134 họ phiên bản → collapse_versions bỏ bản cũ (giữ bản mới nhất)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#63A8E6;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="940" y="270" width="240" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-builder" value="&lt;b&gt;Submission Builder&lt;/b&gt;&lt;br&gt;[Container: Python scripts/]&lt;br&gt;Chạy 2000 câu → keep/judge/listwise + dedup → results.json → pack.py (zip phẳng)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="940" y="430" width="240" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-ingest" value="&lt;b&gt;Ingest Pipeline&lt;/b&gt;&lt;br&gt;[Container: Python ingest/]&lt;br&gt;parse_vbpl → chunk theo cấu trúc Điều/Khoản → textnorm (dấu thanh) → embed → nạp Qdrant + BM25." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="940" y="590" width="240" height="120" as="geometry" /></mxCell>

        <mxCell id="c2-ft" value="&lt;b&gt;Fine-tune Pipeline (offline)&lt;/b&gt;&lt;br&gt;[Container: transformers + peft, GPU]&lt;br&gt;Claude sinh query → mine hard-neg (dense/reranker) → LoRA fine-tune reranker → merge." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="1240" y="430" width="240" height="140" as="geometry" /></mxCell>

        <mxCell id="c2-btc" value="&lt;b&gt;Chấm điểm BTC&lt;/b&gt;&lt;br&gt;[External]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#999999;fontColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="1300" y="270" width="180" height="70" as="geometry" /></mxCell>

        <mxCell id="c2ea" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-person" target="c2-orch"><mxGeometry relative="1" as="geometry" /><mxCell id="c2eal" value="câu hỏi" connectable="0" vertex="1" parent="c2ea"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2eb" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-orch" target="c2-embed"><mxGeometry relative="1" as="geometry" /><mxCell id="c2ebl" value="embed query" connectable="0" vertex="1" parent="c2eb"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2ec" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-orch" target="c2-qdrant"><mxGeometry relative="1" as="geometry" /><mxCell id="c2ecl" value="dense search (vector)" connectable="0" vertex="1" parent="c2ec"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2ed" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-orch" target="c2-bm25"><mxGeometry relative="1" as="geometry" /><mxCell id="c2edl" value="lexical search" connectable="0" vertex="1" parent="c2ed"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2ee" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-orch" target="c2-rerank"><mxGeometry relative="1" as="geometry" /><mxCell id="c2eel" value="rerank (query, điều)" connectable="0" vertex="1" parent="c2ee"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2ef" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-orch" target="c2-llm"><mxGeometry relative="1" as="geometry" /><mxCell id="c2efl" value="judge / listwise / decompose" connectable="0" vertex="1" parent="c2ef"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2eg" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-orch" target="c2-vmap"><mxGeometry relative="1" as="geometry" /><mxCell id="c2egl" value="collapse versions" connectable="0" vertex="1" parent="c2eg"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2eh" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-builder" target="c2-orch"><mxGeometry relative="1" as="geometry" /><mxCell id="c2ehl" value="gọi retrieve/ câu" connectable="0" vertex="1" parent="c2eh"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2ei" style="endArrow=block;html=1;fontSize=10;" edge="1" parent="1" source="c2-builder" target="c2-btc"><mxGeometry relative="1" as="geometry" /><mxCell id="c2eil" value="results.json (zip)" connectable="0" vertex="1" parent="c2ei"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2ej" style="endArrow=block;html=1;fontSize=10;dashed=1;" edge="1" parent="1" source="c2-ingest" target="c2-qdrant"><mxGeometry relative="1" as="geometry" /><mxCell id="c2ejl" value="nạp chunk + vector" connectable="0" vertex="1" parent="c2ej"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
        <mxCell id="c2ek" style="endArrow=block;html=1;fontSize=10;dashed=1;" edge="1" parent="1" source="c2-ft" target="c2-rerank"><mxGeometry relative="1" as="geometry" /><mxCell id="c2ekl" value="tạo model fine-tune" connectable="0" vertex="1" parent="c2ek"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="c3-component" name="C3 - Component (RAG Orchestrator)">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="c3-title" value="C4 — Mức 3: Component — bên trong RAG Orchestrator (luồng truy hồi 1 câu hỏi)" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1000" height="30" as="geometry" /></mxCell>

        <mxCell id="c3-norm" value="&lt;b&gt;1. TextNorm&lt;/b&gt;&lt;br&gt;[backend/textnorm.py]&lt;br&gt;Chuẩn hoá dấu thanh (khỏan→khoản), áp ĐỐI XỨNG query+corpus." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="220" height="90" as="geometry" /></mxCell>
        <mxCell id="c3-decomp" value="&lt;b&gt;2. Decompose (tùy chọn)&lt;/b&gt;&lt;br&gt;[backend/decompose.py]&lt;br&gt;Tách câu tình huống → subqueries (đa-query, tăng recall)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="40" y="200" width="220" height="90" as="geometry" /></mxCell>
        <mxCell id="c3-dense" value="&lt;b&gt;3a. Dense Retrieve&lt;/b&gt;&lt;br&gt;embed → Qdrant top fetch_k (filter-first theo scope)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="320" y="80" width="220" height="90" as="geometry" /></mxCell>
        <mxCell id="c3-bm25" value="&lt;b&gt;3b. BM25 Retrieve&lt;/b&gt;&lt;br&gt;lexical top fetch_k (số điều, mã VB)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="320" y="200" width="220" height="90" as="geometry" /></mxCell>
        <mxCell id="c3-merge" value="&lt;b&gt;4. Merge / RRF&lt;/b&gt;&lt;br&gt;[build_submission_v12.merge_cands]&lt;br&gt;Hợp nhất dense+BM25, khử trùng theo (sk,dieu)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="600" y="140" width="220" height="90" as="geometry" /></mxCell>
        <mxCell id="c3-rerank" value="&lt;b&gt;5. Rerank&lt;/b&gt;&lt;br&gt;[backend/reranker.py]&lt;br&gt;Cross-encoder chấm (query, text) → rerank_score." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="880" y="140" width="220" height="90" as="geometry" /></mxCell>
        <mxCell id="c3-adj" value="&lt;b&gt;6. AdjScore + Collapse&lt;/b&gt;&lt;br&gt;[_rerank_adjust + collapse_versions]&lt;br&gt;Phạt bản hết hiệu lực, boost luật gốc; bỏ bản cũ theo version-map." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="880" y="280" width="220" height="100" as="geometry" /></mxCell>
        <mxCell id="c3-select" value="&lt;b&gt;7. Selection&lt;/b&gt;&lt;br&gt;chọn 1 trong:&lt;br&gt;• adaptive keep (theo score)&lt;br&gt;• judge keep-top-2 (Qwen CÓ/KHÔNG)&lt;br&gt;• listwise (Qwen chọn subset)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="600" y="280" width="220" height="120" as="geometry" /></mxCell>
        <mxCell id="c3-out" value="&lt;b&gt;8. Output Builder&lt;/b&gt;&lt;br&gt;relevant_articles + relevant_docs (rebuild_docs) → trả về." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#85BBF0;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="320" y="320" width="220" height="90" as="geometry" /></mxCell>

        <mxCell id="c3e1" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-norm" target="c3-dense"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e2" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-norm" target="c3-decomp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e3" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-dense" target="c3-merge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e4" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-bm25" target="c3-merge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e5" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-merge" target="c3-rerank"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e6" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-rerank" target="c3-adj"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e7" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-adj" target="c3-select"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e8" style="endArrow=block;html=1;" edge="1" parent="1" source="c3-select" target="c3-out"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3e9" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="c3-decomp" target="c3-dense"><mxGeometry relative="1" as="geometry" /><mxCell id="c3e9l" value="mỗi subquery" connectable="0" vertex="1" parent="c3e9"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
