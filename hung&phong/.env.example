# ========== LLM provider (chat / sinh câu trả lời) ==========
# Bất kỳ endpoint nào tương thích OpenAI API đều dùng được.
# Ollama local:  LLM_BASE_URL=http://localhost:11434/v1 , LLM_API_KEY=ollama
# Gateway/OpenAI: điền key thật, để trống LLM_BASE_URL nếu dùng thẳng OpenAI.
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1

# LLM model — tạo từ Modelfile (scripts/Modelfile.qwen-vbpl) để tăng num_ctx.
LLM_MODEL=qwen-vbpl
LLM_MAX_TOKENS=2048
# 0.0 = bám ngữ cảnh, ổn định, ít rò rỉ suy luận / sai nhãn số hiệu (legal RAG).
LLM_TEMPERATURE=0.0
# Model "thinking" (Qwen3.5...): "none" để tắt reasoning, dồn token vào câu trả lời.
LLM_REASONING_EFFORT=none

# ========== Embedding provider (tách riêng khỏi LLM) ==========
# Mặc định: bge-m3 local qua Ollama (1024-dim, mở, miễn phí, tốt tiếng Việt).
# Có thể đổi sang provider mạnh (text-embedding-3-large, dim 3072) — nhớ re-ingest.
EMBED_API_KEY=ollama
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ========== Qdrant ==========
# Embedded persistent (file://) — không cần Docker, đủ cho ~vài trăm K vector.
# Đổi sang http://localhost:6333 khi chạy Qdrant server (Docker) cho corpus lớn.
QDRANT_URL=file:///D:/py/Chatbot văn bản pháp luật/data/qdrant_local
# vbpl_v2 = corpus luật HIỆN HÀNH từ tmquan/vbpl-vn (vbpl.vn). Ingest: ingest/run_vbpl.py
QDRANT_COLLECTION=vbpl_v2

# ========== Retrieval params ==========
TOP_K=10
RERANK_TOP_K=5

# ========== Ingestion ==========
HF_DATASET=th1nhng0/vietnamese-legal-documents
HF_CACHE_DIR=./data/hf_cache
EMBED_BATCH_SIZE=64
INGEST_LIMIT=0          # 0 = all, hoặc số nguyên để test nhỏ
# Lọc đúng phạm vi cuộc thi: Luật DN & SME (~20k docs / ~250k chunks).
INGEST_SCOPE_FILTER=true

# ========== Backend ==========
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
